#! /usr/bin/env bash
set -exuo pipefail
IFS=$'\n\t'

# Parsers should be automatically picked up from the environment,
# via TreeSitter.language, but in case you're facing issues,
# set the TREE_SITTER_PARSERS envvar to make sure you have access
# to your parsers. This tests specifically looks for the ruby parser.

gitsrc=$(pwd)
version=$(ruby -r ./lib/tree_sitter/version.rb -e 'puts TreeSitter::VERSION')
cp -R examples/test-project /tmp
cd /tmp/test-project
sed -i.bak "s/\$version/$version/" Gemfile
bundle config set --local path vendor
# In order to prevent weird bundler errors comlaining that requested ruby
# version is >= 3.0 and < 3.3.dev, or anything similar, we will need to remove
# the lockfile, and allow bundler to recompute everything.
# As to why we're here, I think it's because we were bundling the previous gems,
# Gemfile.lock is sometimes correct, for the correct platform, and in other
# times it isn't. But who _really_ knows, I only observed this behavior the same
# day working on a different gem, and removing Gemfile.lock did it.
rm Gemfile.lock
bundle install
bundle exec ruby main.rb || echo "You may need to set envvar TREE_SITTER_PARSERS."
